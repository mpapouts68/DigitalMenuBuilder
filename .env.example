# Copy to `.env` for docker compose / Hostman (do not commit `.env`).
# Host port -> container listens on 5000 inside the image.
HOST_PORT=5000

# SQLite (persisted via docker-compose volume `menu_data` at /data)
DATABASE_PATH=/data/menu.db

# Required for production — generate a long random string
JWT_SECRET=change-me-to-a-long-random-secret

# API user accounts (change defaults)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
PRINTER_USERNAME=printer
PRINTER_PASSWORD=printer123

# Card payments: simulated | nbg
CARD_PROVIDER=simulated

# NBG hosted checkout (when CARD_PROVIDER=nbg)
# NBG_BASE_URL=https://test.ibanke-commerce.nbg.gr
# NBG_API_VERSION=85
# NBG_MERCHANT_ID=
# NBG_API_USERNAME=
# NBG_API_PASSWORD=
# NBG_RETURN_URL=https://your-public-host/api/payments/nbg/return
